@page
@model MejorPrecio.Pages.Precios.ConsultarModel
@{
    ViewData["Title"] = "Consultar precios";
}

<h1>Consulta de mejor precio</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-2">
        <label asp-for="Fecha" class="form-label"></label>
        <input asp-for="Fecha" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="ProveedorCodigo" class="form-label">Proveedor</label>
        <select asp-for="ProveedorCodigo" class="form-select">
            <option value="">Todos los proveedores</option>
            @foreach (var proveedor in Model.Proveedores)
            {
                <option value="@proveedor.Codigo">@proveedor.Descripcion</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="CategoriaCodigo" class="form-label">Familia</label>
        <select asp-for="CategoriaCodigo" class="form-select">
            <option value="">Todas las familias</option>
            @foreach (var categoria in Model.Categorias)
            {
                <option value="@categoria.Codigo">@categoria.Descripcion</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="DescripcionProducto" class="form-label"></label>
        <input asp-for="DescripcionProducto" class="form-control" placeholder="Descripción del producto (opcional)" />
    </div>
    <div class="col-md-1 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Buscar</button>
    </div>
</form>

@if (Model.Resultados.Count == 0)
{
    <p class="text-muted">No se encontraron precios vigentes para los filtros seleccionados.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Código de proveedor</th>
                <th>Descripción del proveedor</th>
                <th>Código de producto</th>
                <th>Descripción del producto</th>
                <th>Familia</th>
                <th>Precio unitario</th>
                <th>Vigencia desde</th>
                <th>Vigencia hasta</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fila in Model.Resultados)
            {
                <tr>
                    <td>@fila.ProveedorCodigo</td>
                    <td>@fila.ProveedorDescripcion</td>
                    <td>@fila.ProductoCodigo</td>
                    <td>@fila.ProductoDescripcion</td>
                    <td>@fila.FamiliaDescripcion</td>
                    <td>@fila.PrecioUnitario.ToString("N2")</td>
                    <td>@fila.VigenciaDesde.ToString("dd/MM/yyyy")</td>
                    <td>@fila.VigenciaHasta.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}
